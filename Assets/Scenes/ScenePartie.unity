    titre: "Panne cr\xE9ative..."
    listeObjectif:
    - objectifID: 0
      titre: C'est l'heure de travailler, assis-toi au bureau
    - objectifID: 1
      titre: "Repars \xE0 z\xE9ro dans le document Word"
    - objectifID: 2
      titre: "Efface le croquis entam\xE9"
    etat: 0
    progressionActuelle: 0
    progressionRequise: 3
  - questID: 2
    titre: "\xC0 la chasse aux id\xE9es"
    listeObjectif:
    - objectifID: 0
      titre: "Oh, voil\xE0 une luciole! Attrape-la"
    - objectifID: 1
      titre: "D'o\xF9 vient-elle cette luciole d'ailleurs ?"
    - objectifID: 2
      titre: "\xC9trange..."
