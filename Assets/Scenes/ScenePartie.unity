    progressionActuelle: 0
    progressionRequise: 3
  - questID: 4
    titre: "Coucher les id\xE9es sur le papier"
    listeObjectif:
    - objectifID: 0
      titre: Touche le portail et rentrons!
    - objectifID: 1
      titre: "Assis-toi au bureau et \xE9cris le synopsis"
    - objectifID: 2
      titre: Va au chevet et dessine un croquis
    - objectifID: 3
